NETATMO_CLIENT_ID=your-client-id
NETATMO_CLIENT_SECRET=your-client-secret
NETATMO_REFRESH_TOKEN=your-refresh-token
PORT=8080

# Admin login (server v1.12+) — password protects /admin and the device admin
# routes (rename / block / unblock / delete, Pull & Restart). The public /
# weather page does not require login. Pick a long random string for
# SESSION_SECRET — if empty, a fresh one is generated at boot and existing
# sessions do not survive a server restart.
ADMIN_PASSWORD=change-me
SESSION_SECRET=
