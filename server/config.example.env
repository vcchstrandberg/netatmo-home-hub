NETATMO_CLIENT_ID=your-client-id
NETATMO_CLIENT_SECRET=your-client-secret
NETATMO_REFRESH_TOKEN=your-refresh-token
PORT=8080

# Admin login (server v1.12+) — password protects /admin and the device admin
# routes (rename / block / unblock / delete, Pull & Restart). The public /
# weather page does not require login. Pick a long random string for
# SESSION_SECRET — if empty, a fresh one is generated at boot and existing
# sessions do not survive a server restart.
ADMIN_PASSWORD=change-me
SESSION_SECRET=

# Display brightness (server v1.14+) — the hub computes a 0-100 backlight level
# from the station's location (sunrise/sunset, via the `astral` package) and
# sends it to devices in /weather. Devices with a controllable backlight (the
# ESP32-C6 Touch LCD) apply it; others ignore it. Levels are percentages; the
# ramp is the fade window in minutes centered on each sun event.
BACKLIGHT_DAY=90
BACKLIGHT_NIGHT=10
BACKLIGHT_RAMP_MIN=40
